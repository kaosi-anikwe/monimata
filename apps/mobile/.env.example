# MoniMata Mobile — Environment Variables
# Copy this file to .env and fill in the values.
# Never commit your .env file — it is gitignored.

# ── Required ──────────────────────────────────────────────────────────────────

# Base URL of the MoniMata FastAPI backend.
# No trailing slash. Use https:// in production.
EXPO_PUBLIC_API_URL=https://api.monimata.ng

# Mono Connect public key — frontend widget initialisation.
# Get this from the Mono dashboard: https://app.mono.co
EXPO_PUBLIC_MONO_PUBLIC_KEY=live_pk_xxxxxxxxxxxxxxxxxxxx

# ── Optional ──────────────────────────────────────────────────────────────────

# Sentry DSN for crash reporting (get from sentry.io project settings).
# If not set, Sentry is silently disabled. Required for production.
# EXPO_PUBLIC_SENTRY_DSN=https://077faab9663fb4a8ee5dc8194f7fb5b8@o4511073258569728.ingest.de.sentry.io/4511073260798032

# Override WebSocket server URL if it differs from EXPO_PUBLIC_API_URL.
# By default, the app derives the WS URL automatically (http→ws, https→wss).
# Only set this if your WS server is on a separate host.
# EXPO_PUBLIC_WS_URL=wss://ws.monimata.ng

# App version string included in Sentry events (optional, defaults to 1.0.0).
# EXPO_PUBLIC_APP_VERSION=1.0.0
