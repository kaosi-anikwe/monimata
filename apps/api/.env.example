# Copy this to .env and fill in real values before running.

# ── Core ──────────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:password@localhost:5432/monimata
REDIS_URL=redis://localhost:6379/0
CORS_ORIGINS=["http://localhost:3000","http://localhost:8081"]

# ── JWT (RS256) ────────────────────────────────────────────────────────────────
# Both keys are base64-encoded PEM. Generate with:
#
#   python3 -c "
#   import base64
#   from cryptography.hazmat.primitives import serialization
#   from cryptography.hazmat.primitives.asymmetric import rsa
#   key = rsa.generate_private_key(public_exponent=65537, key_size=2048)
#   priv = key.private_bytes(serialization.Encoding.PEM, serialization.PrivateFormat.PKCS8, serialization.NoEncryption())
#   pub  = key.public_key().public_bytes(serialization.Encoding.PEM, serialization.PublicFormat.SubjectPublicKeyInfo)
#   print('JWT_PRIVATE_KEY=' + base64.b64encode(priv).decode())
#   print('JWT_PUBLIC_KEY='  + base64.b64encode(pub).decode())
#   "
#
# Leave both blank to fall back to HS256 using SECRET_KEY (development only).
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=
SECRET_KEY=change-me-to-a-random-64-byte-hex-string

# ── AI / LLM ──────────────────────────────────────────────────────────────────
# Fernet key for BYOK AI API keys stored in UserAiCredential.
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=change-me-to-a-fernet-key

# ── AES encryption key (32 bytes = 64 hex chars) ─────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
AES_ENCRYPTION_KEY=

# ── Sentry ────────────────────────────────────────────────────────────────────
SENTRY_DSN=                # Leave blank to disable Sentry
SENTRY_TRACES_SAMPLE_RATE=0.2

# ── Email-worker webhook ──────────────────────────────────────────────────────
# Must match the WEBHOOK_SECRET set on the Cloudflare email-worker.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
BANK_ALERT_WEBHOOK_SECRET=

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO    # DEBUG | INFO | WARNING | ERROR
LOG_DIR=logs      # relative to apps/api/; created automatically on startup
