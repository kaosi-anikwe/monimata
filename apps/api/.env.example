# Copy this to .env and fill in real values before running.

# ── Core ──────────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:password@localhost:5432/monimata
REDIS_URL=redis://localhost:6379/0
CORS_ORIGINS=["http://localhost:3000","http://localhost:8081"]

# ── JWT (RS256) ────────────────────────────────────────────────────────────────
# Generate with:
#   openssl genrsa -out private.pem 2048
#   openssl rsa -in private.pem -pubout -out public.pem
# Then paste the PEM content (with \n escaped) here.
# Leave blank to fall back to HS256 using SECRET_KEY (dev only).
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=
SECRET_KEY=change-me-to-a-random-64-byte-hex-string

# ── Mono ──────────────────────────────────────────────────────────────────────
MONO_SECRET_KEY=
MONO_WEBHOOK_SECRET=

# ── Interswitch ───────────────────────────────────────────────────────────────
INTERSWITCH_CLIENT_ID=
INTERSWITCH_CLIENT_SECRET=
INTERSWITCH_ENV=sandbox
# Quickteller bill payment endpoints
INTERSWITCH_QUICKTELLER_URL=https://qa.interswitchng.com/quicktellerservice/api/v5
INTERSWITCH_TERMINAL_ID=3pbl0001

# ── AI / LLM ──────────────────────────────────────────────────────────────────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ── Firebase (FCM push notifications) ────────────────────────────────────────
FIREBASE_SERVICE_ACCOUNT_JSON=

# ── AES encryption key (32 bytes = 64 hex chars) ─────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
AES_ENCRYPTION_KEY=

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO    # DEBUG | INFO | WARNING | ERROR
LOG_DIR=logs      # relative to apps/api/; created automatically on startup
